generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String
  email    String @unique
  password String
  primaryPhoneNumber String ?
  secondaryPhoneNumber String?
  isActive Boolean @default(true)
  profileImage String ?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin")
}

model MenuCategory {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  image       String?
  order       Int     @default(0)
  isActive    Boolean @default(true)
  menuItem    MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@map("menu_category")
}

model Site {
  id String @id @default(uuid())
  siteLogo String
  siteName String
  siteURL String ?
  description String ?
  contactEmail String?
  contactPhone String?
  address      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt()

  @@map("site")

}

model Banner {
  id          String   @id @default(uuid())
  bannerTitle String?
  bannerImage String
  bannerLink  String?
  buttonText  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt()
}

model MenuItem{
  id String @id @default(uuid())
  item String
  price Decimal
  image String

  categoryId String
  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

}

model FeatureCategory{
  id String @id @default(uuid())

}

model Legal{
  id String @id @default(uuid())
type  LegalEnum
content String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt()
}


enum LegalEnum{
  privacy_policy
  terms_and_conditions
}